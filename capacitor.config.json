{
  "appId": "com.mutapatimes.app",
  "appName": "The Mutapa Times",
  "webDir": "www",
  "server": {
    "url": "https://mutapatimes.com",
    "cleartext": false
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#1a1a1a"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#1a1a1a",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#1a1a1a"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}
