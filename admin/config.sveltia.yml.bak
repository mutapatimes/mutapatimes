backend:
  name: github
  repo: mutapatimes/mutapatimes
  branch: main

media_folder: "img/uploads"
public_folder: "/img/uploads"

collections:
  # ─── ARTICLES (originals + drafts) ─────────────────────────────
  # content/articles/ holds ~3,700 markdown files in total (mostly
  # auto-imported wire stories). Sveltia/Decap cannot load that many
  # at once. This collection filters to original articles only, which
  # keeps it under 100 entries and means drafts, featured pieces and
  # the Feature Story of the Week are all reachable. The 'Wire stories'
  # collection below holds the imported ones, on the rare occasion
  # they need editing.
  - name: "articles"
    label: "Articles"
    label_singular: "Article"
    folder: "content/articles"
    create: true
    slug: "{{year}}-{{month}}-{{day}}-{{slug}}"
    summary: "{{title}} - {{date | date('YYYY-MM-DD')}}"
    sortable_fields: ["date", "title", "category", "featured"]
    filter: { field: source_type, value: original }
    view_filters:
      - { label: "Drafts", field: "draft", pattern: true }
      - { label: "Feature Story", field: "feature_story", pattern: true }
      - { label: "Featured", field: "featured", pattern: true }
      - { label: "Spotlight", field: "spotlight", pattern: true }
    fields:
      - { label: "Title", name: "title", widget: "string" }
      - { label: "Publish Date", name: "date", widget: "datetime" }
      - { label: "Author", name: "author", widget: "string", default: "Mutapa Times Staff" }
      - label: "Category"
        name: "category"
        widget: "select"
        options:
          - "Business"
          - "Politics"
          - "Policy"
          - "Tech"
          - "Health"
          - "Crime"
          - "Sport"
          - "Arts"
          - "Culture"
          - "Environment"
          - "Education"
          - "Opinion"
      - { label: "Featured Image", name: "image", widget: "image", required: false }
      - { label: "Summary", name: "summary", widget: "text", pattern: ['.{0,280}', "Must be 280 characters or fewer"] }
      - { label: "Featured on Headlines", name: "featured", widget: "boolean", default: false, hint: "Pin this article to the top of the headlines page" }
      - label: "Headline Position"
        name: "headline_position"
        widget: "number"
        required: false
        default: 0
        min: 0
        max: 10
        hint: "1 = top spot, 2 = second, etc. Leave at 0 for normal date-based ordering."
      - { label: "Source URL", name: "source_url", widget: "string", required: false, hint: "Original article URL (for wire/aggregated articles)" }
      - { label: "Source Type", name: "source_type", widget: "select", required: false, default: "original", options: ["original", "wire"], hint: "How this article was sourced" }
      - { label: "Spotlight", name: "spotlight", widget: "boolean", default: false, required: false, hint: "Show in spotlight section" }
      - { label: "Spotlight title (alternate)", name: "spotlight_title", widget: "string", required: false, hint: "Optional. If set, this is used as the card title in the Spotlight rail instead of the main headline. Useful when the article is also the Feature Story so the two don't visually duplicate." }
      - { label: "Spotlight image (alternate)", name: "spotlight_image", widget: "image", required: false, hint: "Optional. Used in the Spotlight rail instead of the main hero image. Same reason as the alt title." }
      - { label: "Feature Story of the Week", name: "feature_story", widget: "boolean", default: false, required: false, hint: "Promote heavily: top of spotlight, banner on articles + index, footer rail on every article page. Only one article should have this on at a time - the most recent feature_story wins." }
      - { label: "Draft", name: "draft", widget: "boolean", default: false, required: false, hint: "When ticked, the article is kept in the CMS but not published to the site" }
      - { label: "Longform feature", name: "longform", widget: "boolean", default: false, required: false, hint: "NYT-style full-bleed hero, drop cap, scroll-reveal animations" }
      - { label: "Hero eyebrow", name: "hero_eyebrow", widget: "string", required: false, hint: "Small label above the longform headline (e.g. 'BUSINESS LONG READ')" }
      - { label: "Hero image credit", name: "hero_image_credit", widget: "string", required: false }
      - { label: "Read minutes", name: "read_minutes", widget: "string", required: false, hint: "Approx. read time, used by longform articles" }
      - { label: "Body", name: "body", widget: "markdown" }

  # ─── WIRE STORIES (auto-imported) ─────────────────────────────
  # The ~3,600 imported wire articles. Listed here so they're still
  # editable when needed, but kept separate so the main Articles
  # collection stays responsive. Do not create new entries here -
  # fetch_news.py owns this folder.
  - name: "wire_articles"
    label: "Wire stories"
    label_singular: "Wire story"
    folder: "content/articles"
    create: false
    slug: "{{year}}-{{month}}-{{day}}-{{slug}}"
    summary: "{{title}} - {{date | date('YYYY-MM-DD')}}"
    sortable_fields: ["date", "title", "category"]
    filter: { field: source_type, value: wire }
    fields:
      - { label: "Title", name: "title", widget: "string" }
      - { label: "Publish Date", name: "date", widget: "datetime" }
      - { label: "Author", name: "author", widget: "string", required: false }
      - { label: "Category", name: "category", widget: "string", required: false }
      - { label: "Featured Image", name: "image", widget: "image", required: false }
      - { label: "Summary", name: "summary", widget: "text", required: false }
      - { label: "Source URL", name: "source_url", widget: "string", required: false }
      - { label: "Source Type", name: "source_type", widget: "hidden", default: "wire" }
      - { label: "Featured", name: "featured", widget: "boolean", default: false, required: false }
      - { label: "Spotlight", name: "spotlight", widget: "boolean", default: false, required: false }
      - { label: "Body", name: "body", widget: "markdown" }

  # ─── STATIC PAGES (About / Advertising / Privacy / Terms / Subscribe) ─
  - name: "pages"
    label: "Static pages"
    label_singular: "Page"
    files:
      - label: "About"
        name: "about"
        file: "content/pages/about.md"
        fields:
          - { label: "Eyebrow", name: "eyebrow", widget: "string", required: false }
          - { label: "Headline", name: "headline", widget: "string" }
          - { label: "Deck (sub-headline)", name: "deck", widget: "text", required: false }
          - { label: "Body", name: "body", widget: "markdown" }
      - label: "Advertising"
        name: "advertising"
        file: "content/pages/advertising.md"
        fields:
          - { label: "Eyebrow", name: "eyebrow", widget: "string", required: false }
          - { label: "Headline", name: "headline", widget: "string" }
          - { label: "Deck (sub-headline)", name: "deck", widget: "text", required: false }
          - { label: "Body", name: "body", widget: "markdown" }
      - label: "Privacy"
        name: "privacy"
        file: "content/pages/privacy.md"
        fields:
          - { label: "Headline", name: "headline", widget: "string" }
          - { label: "Body", name: "body", widget: "markdown" }
      - label: "Terms"
        name: "terms"
        file: "content/pages/terms.md"
        fields:
          - { label: "Headline", name: "headline", widget: "string" }
          - { label: "Body", name: "body", widget: "markdown" }
      - label: "Subscribe"
        name: "subscribe"
        file: "content/pages/subscribe.md"
        fields:
          - { label: "Eyebrow", name: "eyebrow", widget: "string", required: false }
          - { label: "Headline", name: "headline", widget: "string" }
          - { label: "Deck (sub-headline)", name: "deck", widget: "text", required: false }
          - { label: "Body", name: "body", widget: "markdown", required: false }

  # ─── ROLES / INTERNSHIPS ───────────────────────────────────────
  - name: "roles"
    label: "Roles & Internships"
    label_singular: "Role"
    folder: "content/roles"
    create: true
    slug: "{{slug}}"
    summary: "{{title}} — {{status}}"
    sortable_fields: ["order", "title", "status"]
    fields:
      - { label: "Role Title", name: "title", widget: "string", hint: "e.g. Junior Social Media Assistant" }
      - label: "Status"
        name: "status"
        widget: "select"
        default: "open"
        options: ["open", "closed", "draft"]
        hint: "Closed roles drop out of the public Jobs page and RSS feed"
      - { label: "Display Order", name: "order", widget: "number", default: 10, min: 1, max: 100, hint: "Lower numbers appear first on the Jobs page" }
      - { label: "Summary", name: "summary", widget: "text", pattern: ['.{0,400}', "Must be 400 characters or fewer"], hint: "1-2 sentences shown on the jobs feed card" }
      - { label: "Samples prompt", name: "samples_prompt", widget: "string", required: false, hint: "The prompt that asks applicants for their portfolio link, e.g. 'My social handles / portfolio links:'" }
      - { label: "Apply link anchor", name: "anchor", widget: "string", required: false, hint: "Optional URL fragment for /jobs#... (defaults to a slug of the title)" }
      - { label: "Body (long-form role description)", name: "body", widget: "markdown", required: false }

  # ─── SPONSORS / ADVERTISERS ────────────────────────────────────
  - name: "sponsors"
    label: "Sponsors & Partners"
    label_singular: "Sponsor"
    folder: "content/sponsors"
    create: true
    slug: "{{slug}}"
    summary: "{{name}} — {{active | ternary('LIVE', 'inactive')}}"
    sortable_fields: ["start_date", "name", "active"]
    view_filters:
      - { label: "Currently running", field: "active", pattern: true }
    fields:
      - { label: "Sponsor name", name: "name", widget: "string", hint: "e.g. Safari & Co" }
      - { label: "Active", name: "active", widget: "boolean", default: false, hint: "When ON, the sponsor's editorial strip appears on the configured pages" }
      - { label: "Strip copy", name: "strip_copy", widget: "string", hint: "The text in the editorial strip, e.g. 'Sponsored briefing by Safari & Co — building tomorrow's lodges'" }
      - { label: "Sponsor URL", name: "url", widget: "string", hint: "Where the strip links to (https://...)" }
      - { label: "Logo (optional)", name: "logo", widget: "image", required: false, hint: "Small monochrome mark, ~200px wide PNG/SVG" }
      - label: "Placements"
        name: "placements"
        widget: "select"
        multiple: true
        default: ["news"]
        options: ["news", "articles", "economy", "fx", "markets", "property", "jobs", "weather", "cities"]
        hint: "Which sections this sponsor's strip should appear on"
      - { label: "Start date", name: "start_date", widget: "datetime", required: false }
      - { label: "End date", name: "end_date", widget: "datetime", required: false }
      - { label: "Notes (internal)", name: "notes", widget: "text", required: false, hint: "Sales rep, contract notes, contact name — not published" }
      - { label: "Long copy", name: "body", widget: "markdown", required: false, hint: "Optional longer description for a future /sponsors/{name} page" }

  # ─── SITE SETTINGS (singleton) ─────────────────────────────────
  - name: "settings"
    label: "Site settings"
    files:
      - label: "Site"
        name: "site"
        file: "content/settings/site.yml"
        fields:
          - { label: "Brand name", name: "brand_name", widget: "string", default: "The Mutapa Times" }
          - { label: "Tagline", name: "tagline", widget: "string", default: "Zimbabwe outside-in" }
          - { label: "Editorial contact email", name: "contact_email", widget: "string", default: "news@mutapatimes.com" }
          - { label: "Default OG image", name: "default_og_image", widget: "image", required: false, hint: "Falls back to /img/brand/og-share.png" }
          - { label: "Footer copyright line", name: "footer_copy", widget: "string", default: "© 2020–2026 The Mutapa Times. All rights reserved. Operated from the United Kingdom." }
          - label: "Social handles"
            name: "social"
            widget: "object"
            fields:
              - { label: "X / Twitter", name: "x", widget: "string", default: "mutapatimes" }
              - { label: "Instagram", name: "instagram", widget: "string", default: "mutapatimes" }
              - { label: "LinkedIn (company slug)", name: "linkedin", widget: "string", default: "the-mutapa-times" }
              - { label: "Threads", name: "threads", widget: "string", default: "mutapatimes" }
              - { label: "Facebook (page slug)", name: "facebook", widget: "string", default: "MutapaTimes" }
              - { label: "Bluesky handle", name: "bluesky", widget: "string", default: "mutapatimes.bsky.social" }
              - { label: "TikTok", name: "tiktok", widget: "string", default: "themutapatimes" }
